# Port used by the backend server in local development.
PORT=5000

# Optional service name returned by health endpoint.
SERVICE_NAME=internal-maps-backend

# Runtime environment name.
NODE_ENV=development

# Persistence mode: memory or postgres.
PERSISTENCE_MODE=memory

# PostgreSQL connection values (used only when PERSISTENCE_MODE=postgres).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=internal_maps
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false

# JWT and bootstrap RBAC credentials.
JWT_SECRET=replace-this-jwt-secret-in-production
JWT_EXPIRES_IN=8h
AUTH_BCRYPT_ROUNDS=10
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# In postgres mode, login reads users from DB table "user" (email, role, status, password_hash).
AUTH_ADMIN_EMAIL=admin@internal-maps.local
AUTH_ADMIN_PASSWORD=change-me-admin
AUTH_EDITOR_EMAIL=editor@internal-maps.local
AUTH_EDITOR_PASSWORD=change-me-editor
AUTH_VIEWER_EMAIL=viewer@internal-maps.local
AUTH_VIEWER_PASSWORD=change-me-viewer
