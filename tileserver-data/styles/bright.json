{
  "version": 8,
  "name": "OSM Bright",
  "metadata": {
    "mapbox:origin": "maplibre-gl-js",
    "mapbox:sdk-support": {
      "js": "2.0.0",
      "android": "9.6.0",
      "ios": "9.6.0",
      "macos": "0.7.0"
    }
  },
  "sources": {
    "bangladesh": {
      "type": "vector",
      "url": "mbtiles://bangladesh"
    }
  },
  "sprite": "https://api.maplibre.org/themes/osm-bright/sprite",
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f0ede5"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "bangladesh",
      "source-layer": "water",
      "paint": {
        "fill-color": "#c7d1d7"
      }
    },
    {
      "id": "water-line",
      "type": "line",
      "source": "bangladesh",
      "source-layer": "water",
      "paint": {
        "line-color": "#a5b1b8"
      }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "bangladesh",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#d3d9d3",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "bangladesh",
      "source-layer": "roads",
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.5,
          12,
          2,
          15,
          4
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "bangladesh",
      "source-layer": "buildings",
      "paint": {
        "fill-color": "#d9ccbe"
      },
      "minzoom": 12
    },
    {
      "id": "labels",
      "type": "symbol",
      "source": "bangladesh",
      "source-layer": "names",
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#333333"
      }
    }
  ]
}
