{
  "options": {
    "paths": {
      "root": "/data",
      "fonts": "/data/fonts",
      "sprites": "/data/sprites",
      "styles": "/data/styles",
      "mbtiles": "/data/mbtiles"
    },
    "serveAllStyles": true,
    "persistentCache": true
  },
  "styles": {
    "osm-bright": {
      "style": "bright.json",
      "tilejson": {
        "type": "baselayer",
        "attribution": "© OpenStreetMap contributors | Bangladesh Tileset"
      }
    }
  },
  "data": {
    "bangladesh": {
      "mbtiles": "bangladesh.mbtiles"
    }
  }
}
